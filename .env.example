# ============================================================
# Rev-celerator — Environment Variables
# Copy this file to .env and fill in your real values
# ⚠️  NEVER commit the real .env file to version control
# ============================================================

# --- Postgres ---
DATABASE_URL=postgresql+psycopg://graph:graph@localhost:5432/graphdb

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# --- AI Copilot ---
AI_ENABLED=true

# Option A: Local Ollama (default for Docker Compose)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
AI_MODEL=qwen2.5:0.5b

# Option B: Groq Cloud (free API, use for cloud deployments)
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_your_api_key_here
# AI_MODEL=llama-3.1-8b-instant

# --- Logging ---
LOG_LEVEL=INFO
